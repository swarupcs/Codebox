{$DOMAIN:localhost} {
    # Reverse proxy to API
    reverse_proxy api:3000

    # Compression
    encode gzip

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Logging
    log {
        output stdout
        format json
    }
}
