{
  "info": {
    "name": "CodeBox API",
    "description": "Judge0-compatible code execution API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-Auth-Token",
        "type": "string"
      },
      {
        "key": "value",
        "value": "dev-token",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Health & System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Check if the API is healthy"
          }
        },
        {
          "name": "About",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/about",
            "description": "Get system information"
          }
        },
        {
          "name": "System Info",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/system_info",
            "description": "Get detailed system metrics"
          }
        },
        {
          "name": "Config Info",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/config_info",
            "description": "Get current configuration limits"
          }
        },
        {
          "name": "Workers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/workers",
            "description": "Get worker status"
          }
        },
        {
          "name": "Statistics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/statistics",
            "description": "Get queue statistics"
          }
        },
        {
          "name": "Prometheus Metrics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/metrics",
            "description": "Prometheus metrics endpoint"
          }
        }
      ]
    },
    {
      "name": "Languages",
      "item": [
        {
          "name": "List Active Languages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/languages",
            "description": "Get all active languages"
          }
        },
        {
          "name": "List All Languages",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/languages/all",
            "description": "Get all languages including archived"
          }
        },
        {
          "name": "Get Language by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/languages/71",
            "description": "Get Python language details"
          }
        },
        {
          "name": "Get Statuses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/statuses",
            "description": "Get all submission statuses"
          }
        }
      ]
    },
    {
      "name": "Submissions",
      "item": [
        {
          "name": "Python - Hello World",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"print('Hello, World!')\",\n  \"language_id\": 71\n}"
            },
            "description": "Simple Python hello world"
          }
        },
        {
          "name": "Python - With Input",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"name = input()\\nprint(f'Hello, {name}!')\",\n  \"language_id\": 71,\n  \"stdin\": \"World\"\n}"
            },
            "description": "Python with stdin input"
          }
        },
        {
          "name": "Python - Math",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"import math\\nprint(math.sqrt(144))\\nprint(math.pi)\",\n  \"language_id\": 71\n}"
            },
            "description": "Python with math module"
          }
        },
        {
          "name": "JavaScript - Hello World",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"console.log('Hello, World!');\",\n  \"language_id\": 63\n}"
            },
            "description": "Simple JavaScript hello world"
          }
        },
        {
          "name": "JavaScript - With Input",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"const readline = require('readline');\\nconst rl = readline.createInterface({ input: process.stdin });\\nrl.on('line', (name) => {\\n  console.log(`Hello, ${name}!`);\\n  rl.close();\\n});\",\n  \"language_id\": 63,\n  \"stdin\": \"World\"\n}"
            },
            "description": "JavaScript with stdin"
          }
        },
        {
          "name": "C - Hello World",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"#include <stdio.h>\\n\\nint main() {\\n    printf(\\\"Hello, World!\\\\n\\\");\\n    return 0;\\n}\",\n  \"language_id\": 50\n}"
            },
            "description": "Simple C hello world"
          }
        },
        {
          "name": "C++ - Hello World",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"#include <iostream>\\nusing namespace std;\\n\\nint main() {\\n    cout << \\\"Hello, World!\\\" << endl;\\n    return 0;\\n}\",\n  \"language_id\": 54\n}"
            },
            "description": "Simple C++ hello world"
          }
        },
        {
          "name": "Java - Hello World",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"public class Main {\\n    public static void main(String[] args) {\\n        System.out.println(\\\"Hello, World!\\\");\\n    }\\n}\",\n  \"language_id\": 62\n}"
            },
            "description": "Simple Java hello world"
          }
        },
        {
          "name": "Create Submission (Async)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"print('Async submission')\",\n  \"language_id\": 71\n}"
            },
            "description": "Create submission and get token (poll for result)"
          }
        },
        {
          "name": "Get Submission by Token",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/submissions/:token",
            "description": "Get submission result by token"
          }
        },
        {
          "name": "Delete Submission",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/submissions/:token",
            "description": "Delete a submission"
          }
        },
        {
          "name": "Batch Create Submissions",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions/batch",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"submissions\": [\n    { \"source_code\": \"print(1)\", \"language_id\": 71 },\n    { \"source_code\": \"print(2)\", \"language_id\": 71 },\n    { \"source_code\": \"print(3)\", \"language_id\": 71 }\n  ]\n}"
            },
            "description": "Create multiple submissions at once"
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Runtime Error - Division by Zero",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"print(1/0)\",\n  \"language_id\": 71\n}"
            },
            "description": "Python division by zero error"
          }
        },
        {
          "name": "Compilation Error - C++",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"#include <iostream>\\nint main() {\\n    cout << \\\"Missing namespace\\\";\\n    return 0;\\n}\",\n  \"language_id\": 54\n}"
            },
            "description": "C++ compilation error"
          }
        },
        {
          "name": "Invalid Language ID",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"print('test')\",\n  \"language_id\": 9999\n}"
            },
            "description": "Should return validation error"
          }
        },
        {
          "name": "Missing Source Code",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language_id\": 71\n}"
            },
            "description": "Should return validation error"
          }
        }
      ]
    },
    {
      "name": "Expected Output (Judging)",
      "item": [
        {
          "name": "Correct Answer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"print(42)\",\n  \"language_id\": 71,\n  \"expected_output\": \"42\"\n}"
            },
            "description": "Should return Accepted status"
          }
        },
        {
          "name": "Wrong Answer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/submissions?wait=true",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_code\": \"print(41)\",\n  \"language_id\": 71,\n  \"expected_output\": \"42\"\n}"
            },
            "description": "Should return Wrong Answer status"
          }
        }
      ]
    }
  ]
}
